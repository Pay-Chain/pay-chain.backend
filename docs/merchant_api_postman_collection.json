{
  "info": {
    "_postman_id": "8c3b6f8a-c3e1-4b1a-9c2b-3a4b5c6d7e8f",
    "name": "PaymentKita Merchant API v4.0",
    "description": "Comprehensive collection for integrating with the PaymentKita Merchant Platform. Includes authentication, configuration, and monitoring endpoints.",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "item": [
    {
      "name": "Merchant Profile",
      "item": [
        {
          "name": "Get Current Merchant (/me)",
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "X-API-Key",
                "value": "{{MERCHANT_KEY}}",
                "type": "text"
              }
            ],
            "url": {
              "raw": "{{BASE_URL}}/v1/merchants/me",
              "host": ["{{BASE_URL}}"],
              "path": ["v1", "merchants", "me"]
            }
          },
          "response": []
        },
        {
          "name": "Update Configuration",
          "request": {
            "method": "PATCH",
            "header": [
              {
                "key": "X-API-Key",
                "value": "{{MERCHANT_KEY}}",
                "type": "text"
              },
              {
                "key": "Content-Type",
                "value": "application/json",
                "type": "text"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"callbackUrl\": \"https://your-server.com/webhooks\",\n  \"webhookIsActive\": true\n}"
            },
            "url": {
              "raw": "{{BASE_URL}}/v1/merchants/me",
              "host": ["{{BASE_URL}}"],
              "path": ["v1", "merchants", "me"]
            }
          },
          "response": []
        }
      ]
    },
    {
      "name": "Webhooks & Monitoring",
      "item": [
        {
          "name": "List Webhook Logs",
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "X-API-Key",
                "value": "{{MERCHANT_KEY}}",
                "type": "text"
              }
            ],
            "url": {
              "raw": "{{BASE_URL}}/v1/webhooks/logs?page=1&limit=20",
              "host": ["{{BASE_URL}}"],
              "path": ["v1", "webhooks", "logs"],
              "query": [
                { "key": "page", "value": "1" },
                { "key": "limit", "value": "20" }
              ]
            }
          },
          "response": []
        },
        {
          "name": "Send Test Webhook Ping",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "X-API-Key",
                "value": "{{MERCHANT_KEY}}",
                "type": "text"
              },
              {
                "key": "Content-Type",
                "value": "application/json",
                "type": "text"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"url\": \"https://test-endpoint.io/pk-webhook-test\"\n}"
            },
            "url": {
              "raw": "{{BASE_URL}}/v1/merchants/webhooks/test",
              "host": ["{{BASE_URL}}"],
              "path": ["v1", "merchants", "webhooks", "test"]
            }
          },
          "response": []
        }
      ]
    }
  ],
  "event": [
    {
      "listen": "prerequest",
      "script": {
        "type": "text/javascript",
        "exec": [""]
      }
    },
    {
      "listen": "test",
      "script": {
        "type": "text/javascript",
        "exec": [""]
      }
    }
  ],
  "variable": [
    {
      "key": "BASE_URL",
      "value": "https://api.paymentkita.io",
      "type": "string"
    },
    {
      "key": "MERCHANT_KEY",
      "value": "pk_live_your_key_here",
      "type": "string"
    }
  ]
}
